# "小题快刷" - Apache URL 重写规则
# 将所有请求统一转发到 index.php 入口文件，实现简易路由分发

RewriteEngine On

# 如果请求的是真实存在的文件，直接访问（不转发）
RewriteCond %{REQUEST_FILENAME} !-f

# 如果请求的是真实存在的目录，直接访问（不转发）
RewriteCond %{REQUEST_FILENAME} !-d

# 将所有其他请求转发到 index.php，通过 page 参数传递路径信息
# QSA: 保留原有查询字符串参数  L: 这是最后一条规则，匹配后不再继续
RewriteRule ^(.*)$ index.php?page=$1 [QSA,L]

# ===== 静态资源浏览器缓存策略 =====
# 对 CSS/JS/图片/字体等静态资源设置 7 天缓存，减少重复下载

<IfModule mod_expires.c>
    ExpiresActive On
    # CSS / JS
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    # 图片
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    # 字体
    ExpiresByType font/woff "access plus 30 days"
    ExpiresByType font/woff2 "access plus 30 days"
    ExpiresByType application/font-woff "access plus 30 days"
    ExpiresByType application/font-sfnt "access plus 30 days"
</IfModule>

# 压缩传输（减少传输体积）
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE application/json application/xml text/xml
    AddOutputFilterByType DEFLATE image/svg+xml application/font-woff
</IfModule>
